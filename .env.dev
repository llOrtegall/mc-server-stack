# ─────────────────────────────────────────────────────────────────────────────
# Desarrollo local — WSL / localhost
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── PostgreSQL (corre en Docker via docker-compose.dev.yml) ──────────────────
POSTGRES_DB=mcpanel
POSTGRES_USER=mcadmin
POSTGRES_PASSWORD=devpassword
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mcadmin:devpassword@localhost:5432/mcpanel

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Puertos ──────────────────────────────────────────────────────────────────
PORT=3001
PANEL_URL=http://localhost:3000

# ── Minecraft servers data (ruta local en WSL) ──────────────────────────────
MC_DATA_PATH=./data/servers

# ── Backups locales (sin R2 en dev) ──────────────────────────────────────────
# Si R2_ACCOUNT_ID está vacío, los backups se guardan en ./data/backups
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

BACKUP_LOCAL_PATH=./data/backups

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Auto-shutdown ────────────────────────────────────────────────────────────
AUTO_SHUTDOWN_MINUTES=10

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
