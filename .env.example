# ─────────────────────────────────────────────
# MC Panel — Variables de entorno
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=mcpanel
POSTGRES_USER=mcadmin
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD_SEGURA

# ── Redis ───────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTA_PASSWORD_SEGURA

# ── JWT Auth ────────────────────────────────
JWT_SECRET=GENERA_UN_SECRET_LARGO_ALEATORIO_AQUI
JWT_EXPIRES_IN=24h

# ── Admin (único usuario del panel) ─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTA_PASSWORD_SEGURA

# ── Cloudflare R2 (backups) ─────────────────
# Obtén estas credenciales en: dash.cloudflare.com > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=tu_account_id_de_cloudflare
R2_ACCESS_KEY_ID=tu_r2_access_key
R2_SECRET_ACCESS_KEY=tu_r2_secret_key
R2_BUCKET_NAME=mc-backups

# ── URLs públicas (subdominios) ──────────────
NEXT_PUBLIC_API_URL=https://api.lortegal.com
NEXT_PUBLIC_WS_URL=wss://api.lortegal.com

# ── Auto-shutdown ────────────────────────────
# Minutos sin jugadores antes de apagar el servidor
AUTO_SHUTDOWN_MINUTES=10
