{
  "name": "mc-api",
  "version": "1.0.0",
  "description": "MC Panel Backend — Express + TypeScript + Clean Architecture",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
