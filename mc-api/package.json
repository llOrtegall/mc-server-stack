    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "@aws-sdk/client-s3": "^3.650.0",
    "@aws-sdk/lib-storage": "^3.650.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "node-cron": "^3.0.3",
    "minecraft-rcon": "^0.2.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "zod": "^3.23.8",
